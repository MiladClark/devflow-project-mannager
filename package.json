{
  "name": "devflow-manager",
  "productName": "DevFlow Manager",
  "version": "0.1.18",
  "description": "Windows desktop app to create, run, monitor and configure local dev projects",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/build-icon.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "clean:build": "node scripts/clean-build.mjs",
    "build-icon": "node scripts/build-icon.mjs",
    "package": "node scripts/clean-build.mjs && npm run build && node scripts/package-portable.mjs",
    "package:mac": "node scripts/build-icon.mjs && npx electron-builder --mac",
    "release:folder": "node scripts/make-release.mjs",
    "package:zip": "node scripts/package-zip.mjs",
    "package:zip:mac": "node scripts/package-zip-mac.mjs",
    "release:publish": "node scripts/publish-release.mjs",
    "sign:windows": "node scripts/sign-windows.mjs"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@fontsource/poppins": "^5.2.7",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "decode-ico": "^0.4.1",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.26.0",
    "png-to-ico": "^3.0.2",
    "png2icons": "^2.0.1",
    "rcedit": "^5.0.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.10.0",
    "semver": "^7.8.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.0.0",
    "to-ico": "^1.1.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-electron": "^1.1.0",
    "zustand": "^5.0.2"
  }
}

{
  "name": "devflow-manager",
  "productName": "DevFlow Manager",
  "version": "0.1.7",
  "description": "Windows desktop app to create, run, monitor and configure local dev projects",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/build-icon.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "clean:build": "node scripts/clean-build.mjs",
    "package": "node scripts/clean-build.mjs && npm run build && node scripts/package-portable.mjs",
    "release:folder": "node scripts/make-release.mjs",
    "package:zip": "node scripts/package-zip.mjs",
    "release:publish": "node scripts/publish-release.mjs"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@fontsource/poppins": "^5.2.7",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "decode-ico": "^0.4.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.469.0",
    "png-to-ico": "^3.0.2",
    "rcedit": "^5.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "semver": "^7.8.5",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.0.0",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "zustand": "^5.0.2"
  }
}
